# ──────────────────────────────────────────────
# FIFA World Cup 2026 Scheduler — Backend Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# HOW TO FIND YOUR SUPABASE CREDENTIALS:
#   1. Go to https://supabase.com and sign in
#   2. Select your project
#   3. Click the ⚙ Settings icon in the left sidebar
#   4. Click "API" under Configuration
#   5. Copy "Project URL" → paste as SUPABASE_URL
#   6. Copy "anon public" key → paste as SUPABASE_ANON_KEY
#   7. Copy "service_role" key → paste as SUPABASE_SERVICE_KEY
#      (⚠ Keep the service_role key SECRET — never expose in frontend)
# ──────────────────────────────────────────────

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT secret for signing auth tokens (pick any long random string)
JWT_SECRET=change-me-to-a-random-secret-string-at-least-32-chars

# Server port
PORT=3000
